(library
 (name mini_ml)
 (public_name mini_ml_parser)
 (libraries sexplib0)
 ; -27 (unused-var-strict): re2ocaml may emit actions that don't reference
 ; yyrecord (e.g. the EOF action). Suppressed library-wide.
 (flags (:standard -w -27))
 (inline_tests)
 (preprocess (pps ppx_sexp_conv ppx_inline_test)))

(menhir
 (modules parser))

; Regenerate lexer.ml from lexer.re2c when re2ocaml is on PATH (developer
; machines). The generated file is promoted into the source tree and
; committed, so consumers who lack re2ocaml just use the committed copy.
; --no-generation-date keeps the promoted output byte-stable so the
; committed file does not drift on every build.
(rule
 (target lexer.ml)
 (deps lexer.re2c)
 (mode promote)
 (enabled_if %{bin-available:re2ocaml})
 (action (run re2ocaml --no-generation-date -o %{target} %{deps})))
